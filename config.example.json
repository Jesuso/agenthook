{
  "//": "Copy to config.json and fill in. Holds NON-SECRET wiring only. Tokens and the",
  "//secrets": "webhook secret come from .env (copy .env.example). config.json is gitignored.",

  "provider": "asana",
  "port": 4123,

  "trigger": "@agent",
  "maxConcurrent": 3,
  "fullAuto": true,

  "repoPath": "/absolute/path/to/the/repo/agents/work/in",
  "claudeBin": "claude",
  "worktreePrefix": "../agenthook-worktrees",

  "dataDir": "./.runtime",
  "logDir": "./logs",
  "instructionsFile": "./INSTRUCTIONS.md",
  "publicUrlFile": "./.runtime/public_url.txt",

  "providers": {
    "asana": {
      "userGid": "YOUR_ASANA_USER_GID",
      "workspaceGid": "YOUR_WORKSPACE_GID",
      "myTasksGid": "YOUR_MY_TASKS_LIST_GID"
    },
    "github": {
      "repo": "owner/repo",
      "assigneeLogin": "your-github-username"
    }
  }
}
