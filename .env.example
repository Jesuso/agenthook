# Copy to .env and fill in. .env is gitignored and auto-loaded by the receiver.
# Shell-exported vars take precedence over values here.

# --- Asana (provider: "asana") ---
# Personal Access Token, format 2/<userGid>/<secret>. https://app.asana.com/0/my-apps
ASANA_TOKEN=

# --- GitHub (provider: "github") ---
# A token with repo + admin:repo_hook scope.
GITHUB_TOKEN=
# The HMAC secret you set on the repo webhook (a long random string you choose).
WEBHOOK_SECRET=
