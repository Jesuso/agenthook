{
  "name": "agenthook",
  "version": "0.1.0",
  "description": "Event-driven agentic development. Webhook in, coding agent out. No polling loops.",
  "type": "module",
  "bin": {
    "agenthook": "bin/agenthook.js"
  },
  "files": [
    "bin",
    "src",
    "SECURITY.md",
    "INSTRUCTIONS.example.md",
    "agenthook.config.example.json"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "agenthook": "node bin/agenthook.js",
    "prepublishOnly": "npm run typecheck"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "agent",
    "agents",
    "ai",
    "claude",
    "webhook",
    "automation",
    "devtools",
    "pipeline",
    "kanban",
    "coding-agent",
    "asana",
    "jira"
  ],
  "author": "Ignacio Ortiz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jesuso/agenthook.git"
  },
  "homepage": "https://github.com/Jesuso/agenthook#readme",
  "bugs": {
    "url": "https://github.com/Jesuso/agenthook/issues"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  }
}
